# Copy this file to ".env" (same folder) and fill in real values.
# Never commit the real .env file to git or share it publicly.

# Port the backend server runs on
PORT=4000

# Razorpay keys — get these from the Razorpay Dashboard > Settings > API Keys
# Use TEST keys while developing, LIVE keys only once you're ready to accept real payments.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Admin login for /admin panel
ADMIN_USERNAME=admin
# Generate a bcrypt hash for your real password (see README "Setting the admin password")
ADMIN_PASSWORD_HASH=$2a$10$replace_this_with_a_real_bcrypt_hash

# Secret used to sign admin login tokens — make this a long random string
JWT_SECRET=change_this_to_a_long_random_string

# Comma-separated list of origins allowed to call this API (your live site URL)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
